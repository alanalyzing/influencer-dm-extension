{
  "manifest_version": 3,
  "name": "Influencer DM Manager",
  "version": "10.1.0",
  "description": "Multi-platform influencer engagement manager for Instagram, Threads, LinkedIn, and X (Twitter). Bulk outreach, keyword scan, DM templates, connection/follow + DM logic, tweet reply fallback, waitlist, dashboard analytics, CSV import/export.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://www.threads.net/*",
    "https://www.threads.com/*",
    "https://www.linkedin.com/*",
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["js/content.js"],
      "css": ["css/overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.threads.net/*", "https://www.threads.com/*"],
      "js": ["js/threads-content.js"],
      "css": ["css/overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["js/linkedin-content.js"],
      "css": ["css/overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["js/x-content.js"],
      "css": ["css/overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
